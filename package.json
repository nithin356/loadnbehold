{
  "name": "loadnbehold",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@loadnbehold/web",
    "dev:admin": "turbo dev --filter=@loadnbehold/admin",
    "dev:server": "turbo dev --filter=@loadnbehold/server",
    "build": "turbo build",
    "build:web": "turbo build --filter=@loadnbehold/web",
    "build:admin": "turbo build --filter=@loadnbehold/admin",
    "build:server": "turbo build --filter=@loadnbehold/server",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "clean": "turbo clean",
    "db:seed": "pnpm --filter @loadnbehold/server run db:seed",
    "db:reset": "pnpm --filter @loadnbehold/server run db:reset"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.33.0"
}
