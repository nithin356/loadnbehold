{
  "expo": {
    "name": "LoadNBehold",
    "slug": "loadnbehold",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "loadnbehold",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.loadnbehold.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to find nearby outlets and track deliveries.",
        "NSCameraUsageDescription": "Camera access is needed to upload proof of delivery photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.loadnbehold.app",
      "googleServicesFile": "./apps/mobile/google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-image-picker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "We need your location to find nearby outlets and track deliveries."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.loadnbehold",
          "enableGooglePay": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "03169fc1-74f0-4974-b332-b32e38724290"
      }
    },
    "owner": "clytanapp"
  }
}
